# resume-routine environment variables
#
# Copy this file to .env (not committed) and fill in real values, OR set
# these as Routine env vars in the Claude Code Routine UI.
#
# The Routine reads every var at runtime and fails fast with a clear error
# if any is missing. Do NOT commit the populated .env.

# Google Drive folder ID where the tailored resume .docx is uploaded.
# Get this from the folder URL: https://drive.google.com/drive/folders/<THIS_PART>
# The Drive identity the Routine uses (service account or OAuth) needs write
# access to this folder.
RESUME_DRIVE_FOLDER_ID=

# Google Drive folder ID where the JD + screening-prep notes .txt is uploaded.
# Same shape as above. Same identity needs write access.
JD_DRIVE_FOLDER_ID=

# Apps Script Web App URL that receives the completion POST.
# Deploy the Web App in your Apps Script project, set access to "Anyone"
# (it validates the shared secret in the POST body), and paste the URL here.
# Format: https://script.google.com/macros/s/<DEPLOYMENT_ID>/exec
APPS_SCRIPT_WEBAPP_URL=

# Shared secret included verbatim in the POST body to the Apps Script Web App.
# Generate a long random string (e.g., `openssl rand -hex 32`). The Apps
# Script compares this against its own stored copy and rejects the request
# on mismatch. Treat as a credential: do not log, echo, or commit.
WEBAPP_SECRET=
